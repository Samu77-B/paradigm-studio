# ============================================
# JAVASCRIPT DIRECTORY SECURITY
# ============================================

# Disable directory browsing
Options -Indexes

# Prevent symlink attacks
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# Only allow JavaScript files
<FilesMatch "\.(js)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Block all other file types (including PHP, JSON config files, etc.)
<FilesMatch "\.(php|phtml|php3|php4|php5|phps|pl|py|jsp|asp|sh|cgi|exe|dll|bat|cmd|json|txt|md|html|htm)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to hidden files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
